{
	"extends": "@wordpress/stylelint-config/scss",
	"rules": {
		"at-rule-no-unknown": null,
		"scss/at-rule-no-unknown": [
			true,
			{
				"ignoreAtRules": [
					"view-transition"
				]
			}
		],
		"property-no-unknown": [
			true,
			{
				"ignoreProperties": [
					"navigation"
				]
			}
		],
		"selector-class-pattern": null,
		"length-zero-no-unit": [
			true,
			{
				"ignoreFunctions": [
					"var"
				]
			}
		]
	}
}
